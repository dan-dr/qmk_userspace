#!/usr/bin/env nu

def tracked-backup-target [repo: path, backup_path: path] {
    let backup_relative = try {
        $backup_path | path relative-to $repo
    } catch {
        error make {msg: $"Argos backup must stay inside the repository so it can be committed: ($backup_path)"}
    }
    let tracked = (^git -C $repo ls-files --error-unmatch -- $backup_relative | complete)
    if $tracked.exit_code == 0 {
        return {relative: $backup_relative, commit_paths: [$backup_relative]}
    }

    let backup_hash = (^git -C $repo hash-object -- $backup_relative | str trim)
    let deleted_paths = (^git -C $repo ls-files --deleted | lines)
    mut moved_from = null
    for candidate in $deleted_paths {
        let candidate_hash = (^git -C $repo rev-parse $"HEAD:($candidate)" | str trim)
        if $candidate_hash == $backup_hash {
            $moved_from = $candidate
            break
        }
    }
    if $moved_from == null {
        error make {msg: $"Argos backup path must already be tracked by Git: ($backup_relative)"}
    }
    {relative: $backup_relative, commit_paths: [$backup_relative $moved_from]}
}

def commit-argos-backup [repo: path, backup_relative: path, commit_paths: list<string>] {
    ^git -C $repo add --intent-to-add -- $backup_relative
    if $env.LAST_EXIT_CODE != 0 {
        error make {msg: $"Could not prepare Argos backup for commit: ($backup_relative)"}
    }

    let diff = (^git -C $repo diff --quiet HEAD -- ...$commit_paths | complete)
    if $diff.exit_code == 0 {
        print "Argos backup unchanged; no commit needed"
        return
    }
    if $diff.exit_code != 1 {
        error make {msg: $"Could not inspect Argos backup changes: ($backup_relative)"}
    }

    print $"Committing Argos backup: ($backup_relative)"
    ^git -C $repo commit --only -m "chore: update Argos backup" -- ...$commit_paths
    if $env.LAST_EXIT_CODE != 0 {
        error make {msg: "Argos backup commit failed; nothing was flashed"}
    }
}

def main [
    --half: string = "both" # Half to flash: right, left, or both
    --backup-only            # Export Argos without flashing
    --no-backup              # Flash without exporting Argos first
    --output: path           # Tracked Argos backup path inside this repository
    --dry-run                # Print the planned actions only
] {
    let valid_halves = [right left both]
    if $half not-in $valid_halves {
        error make {msg: $"invalid --half '($half)'; expected right, left, or both"}
    }
    if $backup_only and $no_backup {
        error make {msg: "--backup-only and --no-backup cannot be used together"}
    }

    let repo = ($env.FILE_PWD | path dirname)
    let backup_path = if $output == null {
        $repo | path join "keyboards" "bastardkb" "charybdis" "4x6" "keymaps" "ddyo" "argos.json"
    } else {
        $output | path expand
    }
    let backup_target = if $no_backup {
        null
    } else {
        tracked-backup-target $repo $backup_path
    }
    let backup_relative = if $no_backup { null } else { $backup_target.relative }
    let backup_command = [
        cargo run --quiet --locked
        --manifest-path ($repo | path join "tools" "argosctl" "Cargo.toml")
        -- backup --output $backup_path --force --wait --require-right-half
    ]
    let restore_command = [
        cargo run --quiet --locked
        --manifest-path ($repo | path join "tools" "argosctl" "Cargo.toml")
        -- restore --input $backup_path --wait --require-right-half
    ]
    let flash_command = [
        mise exec -- qmk flash
        -kb bastardkb/charybdis/4x6/splinktegrated_rev1
        -km ddyo
    ]

    if $dry_run {
        if not $no_backup {
            print $"Backup: ($backup_command | str join ' ')"
            print $"Commit if changed: ($backup_relative) as 'chore: update Argos backup'"
        }
        if not $backup_only {
            let halves = if $half == "both" { [right left] } else { [$half] }
            for current_half in $halves {
                print $"Flash ($current_half): ($flash_command | str join ' ')"
            }
            if not $no_backup {
                print $"Restore: ($restore_command | str join ' ')"
            }
        }
        return
    }

    cd $repo
    if not $no_backup {
        print $"Backing up Argos to ($backup_path)"
        run-external ...$backup_command
        if $env.LAST_EXIT_CODE != 0 {
            error make {msg: "Argos backup failed; nothing was flashed"}
        }
        commit-argos-backup $repo $backup_relative $backup_target.commit_paths
    }
    if $backup_only {
        return
    }

    let halves = if $half == "both" { [right left] } else { [$half] }
    for current_half in $halves {
        print $"Starting QMK for the ($current_half) half; enter bootloader now or when QMK begins waiting"
        with-env {QMK_FLASH_GUARD_BYPASS: "backup-first-wrapper"} {
            run-external ...$flash_command
        }
        if $env.LAST_EXIT_CODE != 0 {
            error make {msg: $"QMK flash failed for the ($current_half) half"}
        }
    }

    if not $no_backup {
        print "Waiting for the right/trackball half over normal USB to restore Argos"
        run-external ...$restore_command
        if $env.LAST_EXIT_CODE != 0 {
            error make {msg: "Argos restore or verification failed after flashing"}
        }
    }
}
